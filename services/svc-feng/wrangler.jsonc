{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "hexastral-svc-feng",
  "main": "src/index.ts",
  "compatibility_date": "2025-09-03",
  "compatibility_flags": ["nodejs_compat"],
  "observability": { "enabled": true },
  "limits": {
    "cpu_ms": 300000
  },
  // Workers AI — Stage-3 text synthesis runs on the shared CF router
  // (@zhop/ai-vision/router, Kimi/Qwen3/GLM). Same LLM base as the rest of the matrix.
  "ai": { "binding": "AI" },
  // Public env vars (non-secret). MAPBOX_TOKEN is a secret — set via:
  //   wrangler secret put MAPBOX_TOKEN
  // Gemini key is `GEMINI_API_KEY` — VLM (Stage-1 vision) ONLY; text synthesis is on Workers AI.
  "vars": {
    "ENV": "production",
    // Default tile style; can be overridden per request.
    "MAPBOX_STATIC_STYLE": "mapbox/satellite-v9"
  },
  // R2 buckets — raw + annotated map cache (transient), plus user floor plans
  // (owned/permanent, purged with the site — NOT lifecycle-GC'd).
  //
  // Create with:
  //   wrangler r2 bucket create feng-maps
  //   wrangler r2 bucket create feng-annotated
  //   wrangler r2 bucket create feng-floorplans
  // and paste preview names if developing against staging.
  "r2_buckets": [
    {
      "binding": "MAPS_CACHE",
      "bucket_name": "feng-maps"
    },
    {
      "binding": "ANNOTATED_CACHE",
      "bucket_name": "feng-annotated"
    },
    {
      "binding": "FLOORPLAN_CACHE",
      "bucket_name": "feng-floorplans"
    }
  ],
  // Tail worker for logs (matches the rest of the services).
  "tail_consumers": [
    {
      "service": "svc-tail"
    }
  ]
}
