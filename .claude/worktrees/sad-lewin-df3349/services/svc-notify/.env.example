# svc-notify - Cloudflare Worker Secrets
# Copy to .env.production.secrets and fill in real values.
# Upload with: bun secrets:sync (calls scripts/sync-secrets.js)
# These are secrets - do NOT put them in wrangler.jsonc [vars].

# Shared internal service-to-service auth key (must match hexastral-api INTERNAL_KEY).
# Generate with: openssl rand -hex 32
INTERNAL_KEY=
