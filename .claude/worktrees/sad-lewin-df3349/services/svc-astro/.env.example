# svc-astro 环境变量示例
# 复制此文件为 .env 并填入真实值（仅本地开发用）
# 生产环境请使用 wrangler secret put 注入，不要提交 .env 到仓库

# ── AI Model Keys ─────────────────────────────────────────────────────────────

# Google Gemini API Key
# 用途: Gemini 3.1 Pro Vision (纯面相/手相 VLM 结构化特征提取及分析)
#       其余文本/对话能力已迁移到 Cloudflare Workers AI
# 申请: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# ── Runtime ───────────────────────────────────────────────────────────────────

# 运行环境 (development | production)
ENVIRONMENT=development
