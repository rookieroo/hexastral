# svc-mailer — Cloudflare Worker Secrets
# Copy to .env.production.secrets and fill in real values.
# Upload with: bun secrets:sync (calls scripts/sync-secrets.js)
# These are secrets — do NOT put them in wrangler.jsonc [vars].

# AWS IAM credentials for SES (transactional email).
# Create a policy-scoped IAM user at: https://console.aws.amazon.com/iam/
# Required SES permission: ses:SendRawEmail
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
