# svc-admin-notify - Cloudflare Worker Secrets
# Copy to .env.production.secrets and fill in real values.
# Upload with: bun secrets:sync (calls scripts/sync-secrets.js)
# These are secrets - do NOT put them in wrangler.jsonc [vars].

# Telegram Bot token - create via @BotFather
TELEGRAM_BOT_TOKEN=

# Admin chat or group ID
# - DM the bot first, then visit: https://api.telegram.org/bot<TOKEN>/getUpdates
# - For a group: add bot to group, send a message, check getUpdates for negative chat.id
TELEGRAM_CHAT_ID=
# ── Optional alerting channels (leave blank to disable) ───────────────────────

# Pushover (ops alerting)
# Get app token from: https://pushover.net/apps/build
PUSHOVER_API_TOKEN=
PUSHOVER_USER_KEY=

# Slack incoming webhook URL
# Create at: https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK_URL=

# Discord webhook URL
# Create at: Server Settings → Integrations → Webhooks
DISCORD_WEBHOOK_URL=