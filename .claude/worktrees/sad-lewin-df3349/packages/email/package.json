{
  "name": "@zhop/email",
  "version": "1.0.6",
  "private": true,
  "description": "Email templates and utilities for Zhop",
  "main": "index.ts",
  "types": "./index.ts",
  "type": "module",
  "exports": {
    ".": "./index.ts",
    "./providers": "./providers/index.ts",
    "./providers/*": "./providers/*.ts",
    "./service-client": "./service-client.ts",
    "./templates": "./templates/index.tsx"
  },
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist .turbo node_modules",
    "typecheck": "tsc --noEmit",
    "with-env": "dotenv -e ../../.env --",
    "update": "bun update"
  },
  "dependencies": {
    "@aws-sdk/client-ses": "^3.785.0",
    "@react-email/components": "^1.0.6",
    "@react-email/tailwind": "^1.2.2",
    "@t3-oss/env-nextjs": "^0.11.1",
    "resend": "^4.8.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@zhop/typescript-config": "workspace:*"
  }
}
