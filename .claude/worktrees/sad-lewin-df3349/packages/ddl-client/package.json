{
  "name": "@zhop/ddl-client",
  "version": "1.0.0",
  "private": true,
  "description": "Deferred Deep Link fingerprint collection and App Store redirect — reusable across hexastral-web, turborca-web, etc.",
  "exports": {
    ".": "./src/index.ts",
    "./types": "./src/types.ts",
    "./fingerprint": "./src/fingerprint.ts",
    "./client": "./src/client.ts",
    "./redirect": "./src/redirect.ts",
    "./growth-utm": "./src/growth-utm.ts"
  },
  "typesVersions": {
    "*": {
      "*": ["src/*"]
    }
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf .turbo node_modules"
  },
  "devDependencies": {
    "@zhop/typescript-config": "workspace:*"
  }
}
