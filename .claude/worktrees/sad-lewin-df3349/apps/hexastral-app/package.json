    "@rn-primitives/slot": "^1.2.0",
    "@rn-primitives/switch": "^1.2.0",
    "@rn-primitives/tabs": "^1.2.0",
    "@sentry/react-native": "~7.2.0",
    "@shopify/react-native-skia": "2.2.12",
