'use client'

import Link from 'next/link'
import { useState } from 'react'
import type { {{slugPascal}}TryCopy } from './page'

export function {{slugPascal}}TryClient({
  copy,
  locale,
}: {
  copy: {{slugPascal}}TryCopy
  locale: string
}) {
  const [value, setValue] = useState('')
  const [busy, setBusy] = useState(false)
  const [err, setErr] = useState<string | null>(null)

  const submit = async (e: React.FormEvent) => {
    e.preventDefault()
    if (!value.trim() || busy) return
    setBusy(true)
    setErr(null)
    try {
      // TODO: wire to the real endpoint, e.g.
      // const res = await fetch('/api/{{slug}}/...', {
      //   method: 'POST',
      //   headers: { 'content-type': 'application/json' },
      //   body: JSON.stringify({ value }),
      // })
      // if (!res.ok) throw new Error(`${res.status}`)
      throw new Error('Not implemented yet')
    } catch (e2) {
      setErr(e2 instanceof Error ? e2.message : copy.err)
    } finally {
      setBusy(false)
    }
  }

  return (
    <main
      style={{
        minHeight: '100vh',
        backgroundColor: '#FAFAFA',
        color: '#18181B',
        padding: '64px 20px',
      }}
    >
      <div style={{ maxWidth: 560, margin: '0 auto' }}>
        <h1 style={{ fontSize: 32, fontWeight: 500, letterSpacing: -0.4, marginBottom: 32 }}>
          {copy.title}
        </h1>

        <form onSubmit={submit} style={{ display: 'flex', flexDirection: 'column', gap: 24 }}>
          <div>
            <label
              style={{
                display: 'block',
                fontSize: 11,
                letterSpacing: 1.6,
                textTransform: 'uppercase',
                color: 'rgba(24,24,27,0.65)',
