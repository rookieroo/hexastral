# Yuun (auspice-app) — local development env
# Copy to `.env.local` and fill in. Production values also live in eas.json.

EXPO_PUBLIC_API_URL=https://api.hexastral.com
EXPO_PUBLIC_ENV=development

# After `eas init` — UUID from Expo dashboard / app.json extra.eas.projectId
# EXPO_PUBLIC_EAS_PROJECT_ID=

EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=

EXPO_PUBLIC_REVENUECAT_IOS_KEY=
EXPO_PUBLIC_REVENUECAT_ANDROID_KEY=
