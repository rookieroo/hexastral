{
  "name": "@zhop/cycle-app",
  "version": "0.1.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "dev": "node_modules/.bin/expo start --dev-client",
    "dev:go": "node_modules/.bin/expo start",
    "ios": "LANG=en_US.UTF-8 LC_ALL=en_US.UTF-8 node_modules/.bin/expo run:ios",
    "ios:device": "LANG=en_US.UTF-8 LC_ALL=en_US.UTF-8 node_modules/.bin/expo run:ios --device",
    "android": "node_modules/.bin/expo run:android",
    "prebuild": "LANG=en_US.UTF-8 LC_ALL=en_US.UTF-8 node ../../scripts/sync-satellite-colors.mjs app.json && LANG=en_US.UTF-8 LC_ALL=en_US.UTF-8 node_modules/.bin/expo prebuild",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "format": "biome format . --write"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-native-google-signin/google-signin": "^15.0.0",
    "@shopify/react-native-skia": "2.2.12",
    "@zhop/astro-core": "workspace:*",
    "@zhop/core-ui": "workspace:*",
    "@zhop/hexastral-icons": "workspace:*",
    "@zhop/hexastral-tokens": "workspace:*",
    "@zhop/portfolio-client": "workspace:*",
    "@zhop/satellite-runtime": "workspace:*",
    "@zhop/satellite-ui": "workspace:*",
    "babel-preset-expo": "~54.0.10",
    "expo": "~54.0.33",
    "expo-apple-authentication": "~8.0.8",
    "expo-constants": "~18.0.13",
    "expo-crypto": "~15.0.8",
    "expo-dev-client": "~6.0.20",
    "expo-haptics": "~15.0.8",
    "expo-linking": "~8.0.11",
    "expo-localization": "~17.0.8",
    "expo-notifications": "~0.32.16",
    "expo-router": "~6.0.23",
    "expo-secure-store": "~15.0.8",
    "expo-sharing": "~14.0.8",
    "expo-status-bar": "~3.0.9",
    "lucide-react-native": "^1.14.0",
    "react": "^19.2.3",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-purchases": "^10.1.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.16.0",
    "react-native-view-shot": "^4.0.3",
    "react-native-worklets": "0.5.1"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@types/react": "^19.1.10",
    "@zhop/expo-env-loader": "workspace:*",
    "@zhop/typescript-config": "workspace:*",
    "typescript": "^5.9.3"
  }
}
