# Yuán app — local development env
# Copy to `.env` and fill in. Production values live in eas.json.

EXPO_PUBLIC_API_URL=https://api.hexastral.com
EXPO_PUBLIC_ENV=development

# RevenueCat keys — get from RevenueCat dashboard for the Yuán app
EXPO_PUBLIC_REVENUECAT_IOS_KEY=
EXPO_PUBLIC_REVENUECAT_ANDROID_KEY=

# EAS project id (after `eas init`)
EXPO_PUBLIC_EAS_PROJECT_ID=
