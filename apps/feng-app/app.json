{
  "expo": {
    "name": "Feng",
    "slug": "feng",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "feng",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0F1E26"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.hexastral.feng",
      "usesAppleSignIn": true,
      "associatedDomains": [
        "applinks:hexastral.com",
        "applinks:www.hexastral.com"
      ],
      "infoPlist": {
        "CFBundleLocalizations": [
          "en",
          "zh-Hans",
          "zh-Hant",
          "ja"
        ],
        "CFBundleDevelopmentRegion": "en",
        "ITSAppUsesNonExemptEncryption": false,
        "NSLocationWhenInUseUsageDescription": "Feng uses your location to fetch satellite imagery and compute the magnetic declination needed for accurate site-alignment analysis.",
        "NSMotionUsageDescription": "Feng reads your device's magnetometer to auto-detect your home's facing direction before you confirm it on the satellite image.",
        "NSPhotoLibraryUsageDescription": "Feng can save your annotated site report as an image to your photo library."
      },
      "privacyManifests": {
        "NSPrivacyAccessedAPITypes": [
          {
            "NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategoryUserDefaults",
            "NSPrivacyAccessedAPITypeReasons": [
              "CA92.1"
            ]
          },
          {
            "NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategorySystemBootTime",
            "NSPrivacyAccessedAPITypeReasons": [
              "35F9.1"
            ]
          },
          {
            "NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategoryDiskSpace",
            "NSPrivacyAccessedAPITypeReasons": [
              "E174.1"
            ]
          },
          {
            "NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategoryFileTimestamp",
            "NSPrivacyAccessedAPITypeReasons": [
              "C617.1"
            ]
          }
        ],
        "NSPrivacyCollectedDataTypes": [],
        "NSPrivacyTracking": false
      }
    },
    "android": {
      "package": "com.hexastral.feng",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0F1E26"
      },
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "extra": {
      "router": {
        "origin": false
      },
      "REVENUECAT_IOS_API_KEY": "REPLACE_WITH_REVENUECAT_IOS_API_KEY",
      "REVENUECAT_ANDROID_API_KEY": "REPLACE_WITH_REVENUECAT_ANDROID_API_KEY",
      "eas": {
        "projectId": "8115f4eb-298e-46e4-bf2f-9539b51a71a4"
      }
    },
    "owner": "useone-tech",
    "plugins": [
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Fēng uses your location to fetch satellite imagery and compute magnetic declination."
        }
      ],
      "expo-router",
      "expo-secure-store",
      "expo-apple-authentication",
      "@react-native-community/datetimepicker",
      [
        "@react-native-google-signin/google-signin",
        {
          "iosClientId": "443209724807-74241r1rvca3nb4io9o6184ddrkhtf7m.apps.googleusercontent.com",
          "iosUrlScheme": "com.googleusercontent.apps.443209724807-74241r1rvca3nb4io9o6184ddrkhtf7m",
          "androidClientId": "443209724807-nt26socuql9j5jmsrd1ve9h8ap7i3ubp.apps.googleusercontent.com"
        }
      ]
    ]
  }
}
