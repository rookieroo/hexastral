{
  "extends": "../../tooling/typescript-config/base.json",
  "compilerOptions": {
    "baseUrl": "../..",
    "paths": {
      "@/*": ["./apps/useone-tech/*"],
      "@zhop/ui/*": ["./packages/ui/src/*"]
    },
    "plugins": [
      {
        "name": "next"
      }
    ]
