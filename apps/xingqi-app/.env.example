# Xingqi — local development env
# Copy to `.env` and fill in. Production values live in eas.json.

EXPO_PUBLIC_API_URL=https://api.hexastral.com
EXPO_PUBLIC_ENV=development

EXPO_PUBLIC_REVENUECAT_IOS_KEY=
EXPO_PUBLIC_REVENUECAT_ANDROID_KEY=

# After `eas init` for com.hexastral.syel
EXPO_PUBLIC_EAS_PROJECT_ID=REPLACE_WITH_EAS_PROJECT_ID
