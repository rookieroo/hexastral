{
  "expo": {
    "name": "Yaul",
    "slug": "coin-cast",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "yaul",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#09090B"
    },
    "ios": {
      "supportsTablet": true,
      "deploymentTarget": "15.1",
      "icon": {
        "light": "./assets/icon.png",
        "dark": "./assets/icon-dark.png",
        "tinted": "./assets/icon-tinted.png"
      },
      "bundleIdentifier": "com.hexastral.yaul",
      "usesAppleSignIn": true,
      "associatedDomains": [
        "applinks:hexastral.com",
        "applinks:www.hexastral.com",
        "applinks:yaul.hexastral.com"
      ],
      "infoPlist": {
        "CFBundleDisplayName": "Yaul"
      },
      "privacyManifests": {
        "NSPrivacyAccessedAPITypes": [
          {
            "NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategoryUserDefaults",
            "NSPrivacyAccessedAPITypeReasons": [
              "CA92.1"
            ]
          },
          {
            "NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategorySystemBootTime",
            "NSPrivacyAccessedAPITypeReasons": [
              "35F9.1"
            ]
          },
          {
            "NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategoryDiskSpace",
            "NSPrivacyAccessedAPITypeReasons": [
              "E174.1"
            ]
          },
          {
            "NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategoryFileTimestamp",
            "NSPrivacyAccessedAPITypeReasons": [
              "C617.1"
            ]
          }
        ],
        "NSPrivacyCollectedDataTypes": [],
        "NSPrivacyTracking": false
      },
      "appleTeamId": "L9Z47DW56X"
    },
    "android": {
      "package": "com.hexastral.yaul",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#09090B"
      }
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "c07ecae2-d37c-4f8c-8dfa-3a3ceb6ef002"
      },
      "REVENUECAT_IOS_API_KEY": "REPLACE_WITH_REVENUECAT_IOS_API_KEY",
      "REVENUECAT_ANDROID_API_KEY": "REPLACE_WITH_REVENUECAT_ANDROID_API_KEY"
    },
    "owner": "useone-tech",
    "experiments": {
      "typedRoutes": true
    },
    "plugins": [
      "expo-router",
      "expo-dev-client",
      "./plugins/withIosPodDeploymentTarget.cjs",
      [
        "expo-image-picker",
        {
          "photosPermission": "Choose a coin face image for casting.",
          "cameraPermission": false,
          "microphonePermission": false
        }
      ],
      [
        "expo-sensors",
        {
          "motionPermission": "Yaul uses your real motion to drive the virtual coins during sensing casts."
        }
      ]
    ]
  }
}
