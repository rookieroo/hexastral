# Fate app — committed Expo env defaults (loaded first; override in .env.local / .env).
# Secrets never go here — placeholders only.

EXPO_PUBLIC_API_URL=https://api.hexastral.com
EXPO_PUBLIC_ENV=development

# EAS project id — fill after `eas init` (in .env.local, gitignored).
EXPO_PUBLIC_EAS_PROJECT_ID=

# Google Sign-In OAuth client ids (Google Cloud Console → APIs & Services → Credentials).
# Leave blank to hide the "Continue with Google" button (component degrades to unavailable).
#   IOS:  <id>.apps.googleusercontent.com  — type "iOS", bundle com.hexastral.fate.
#         Its REVERSED form (com.googleusercontent.apps.<id>) goes in app.json plugin iosUrlScheme.
#   WEB:  <id>.apps.googleusercontent.com  — type "Web application". This is what mints the
#         idToken; the same value MUST be listed in the API's GOOGLE_OAUTH_AUDIENCES secret.
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
