# HexAstral Web — Local environment variables
# Copy to .env.local and fill in actual values

NEXT_PUBLIC_API_URL=https://api.hexastral.com
# Default growth CTA fallback is Yuel (kindred) when unset — see lib/growth/app-store-urls.ts
NEXT_PUBLIC_APP_STORE_URL=https://apps.apple.com/app/kindred/id6745054798
NEXT_PUBLIC_SITE_URL=https://hexastral.com

# Per-app store URLs (Yuel=soulmatch, Yuun=auspice, Kanyu=fengshui, Yaul=coincast)
NEXT_PUBLIC_APP_STORE_URL_FACEORACLE=
NEXT_PUBLIC_APP_STORE_URL_STARPALACE=
NEXT_PUBLIC_APP_STORE_URL_SOULMATCH=
NEXT_PUBLIC_APP_STORE_URL_FENGSHUI=
NEXT_PUBLIC_APP_STORE_URL_DREAMORACLE=
NEXT_PUBLIC_APP_STORE_URL_EIGHTPILLARS=
NEXT_PUBLIC_APP_STORE_URL_COINCAST=
NEXT_PUBLIC_APP_STORE_URL_AUSPICE=

# Cloudflare Turnstile — public site key (safe to commit/expose)
# Get from: Cloudflare Dashboard → Turnstile → your site → Site Key
NEXT_PUBLIC_TURNSTILE_SITE_KEY=0x4AAAAAACzwgZxj-UShx-9l
