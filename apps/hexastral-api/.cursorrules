## 8. Microservice Integration

### Unified Client Layer

```typescript
// lib/service-clients.ts — single source of truth
async function callService<T>(
  binding: any,
  path: string,
  init?: RequestInit
): Promise<T> {
  const abortSignal = AbortSignal.timeout(10000)  // 10s timeout
  
  try {
    const res = await binding.fetch(
      new Request(`http://internal${path}`, { ...init, signal: abortSignal })
    )
    
    if (!res.ok) throw new ServiceError(`Error: ${res.status}`, res.status)
    return await res.json()
  } catch (err) {
    throw new ServiceError(String(err), 500)
  }
}

// ✅ In route handler
const result = await astroClient.computeHehun(c.env.SVC_ASTRO, payload)

// ❌ Don't do this (no timeout, no error handling)
const res = await c.env.SVC_ASTRO.fetch(new Request(...))
```

---

## 9. Rate Limiting & Cache

### Rate Limiting

```typescript
// Configured in wrangler.jsonc
// "RATE_LIMITER": { "limit": 60, "period": 60 }
// "CHART_RATE_LIMITER": { "limit": 5, "period": 60 }

app.post('/bazi/compute', hmacVerify, async (c) => {
  const userId = c.get('userId')
  
  const { success } = await c.env.CHART_RATE_LIMITER.limit({ key: userId })
  if (!success) throw new HTTPException(429, { message: 'Too many requests' })
  
  // handle...
})
```

### KV Cache

```typescript
// GUARD_KV (24h): divination dedup + rate limit
// DDL_KV (30min): deep link sessions
// FORTUNE_CACHE (7d): fortune results

const cached = await c.env.FORTUNE_CACHE.get(`fortune:${userId}:${date}`)
if (cached) return c.json(JSON.parse(cached))

const result = await generateFortune(userId)
await c.env.FORTUNE_CACHE.put(
  `fortune:${userId}:${date}`,
  JSON.stringify(result),
  { expirationTtl: 7 * 24 * 3600 }
)
```

