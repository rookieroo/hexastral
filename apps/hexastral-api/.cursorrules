## 5. Database (D1 + Drizzle)

### Schema

```typescript
import { sqliteTable, text, integer, index, relations } from 'drizzle-orm/sqlite-core'

export const users = sqliteTable(
  'users',
  {
    id: text('id').primaryKey(),
    email: text('email').unique(),
    is_premium: integer('is_premium', { mode: 'boolean' }).default(false),
    created_at: text('created_at').default('CURRENT_TIMESTAMP'),
  },
  (table) => [
    index('idx_users_email').on(table.email),
    index('idx_users_premium').on(table.is_premium),
  ]
)

export const usersRelations = relations(users, ({ many }) => ({
  readings: many(readings),
}))
```

### Migration Workflow

```bash
# After editing schema.ts
bun db:generate        # Generate migration SQL
bun db:migrate         # Test locally
# Review migrations/*.sql
bun db:migrate:prod    # Deploy to production
```

### Query Patterns

```typescript
import { eq, sql } from 'drizzle-orm'

// ✅ Relational query
const user = await db.query.users.findFirst({
  where: eq(users.id, userId),
  with: { readings: { limit: 10 } }
})

// ✅ Raw SQL (complex queries)
const result = await db.execute(
  sql`SELECT * FROM readings WHERE user_id = ${userId} LIMIT 10`
)

// ✅ Atomic credit update
await db.batch([
  db.update(users).set({ credits: sql`credits - ${cost}` }).where(eq(users.id, userId)),
  db.insert(readings).values({ id: nanoid(), user_id: userId, ... })
])

// ❌ N+1
const user = await db.query.users.findFirst(...)
const readings = await db.query.readings.findMany(...)  // separate queries
```

