## 6. Routes & Validation

### Route Structure

```typescript
import { Hono } from 'hono'
import { zValidator } from '@hono/zod-validator'
import { z } from 'zod/v4'

const app = new Hono()

// ✅ iOS endpoint
app.post('/bazi/compute', hmacVerify, 
  zValidator('json', computeSchema),
  async (c) => {
    const userId = c.get('userId')
    const { year, month, day, hour, city } = c.req.valid('json')
    // handle...
  }
)

// ✅ Web endpoint
app.post('/share/send', turnstileVerify,
  zValidator('json', shareSchema),
  async (c) => {
    // handle...
  }
)

// ❌ Mixed auth
app.post('/bad', hmacVerify, turnstileVerify, (c) => { })
```

### Zod Validation

```typescript
const computeSchema = z.object({
  year: z.number().min(1900).max(2100),
  month: z.number().min(1).max(12),
  day: z.number().min(1).max(31),
  hour: z.number().min(0).max(23),
  city: z.string().min(1),
})

app.post('/compute',
  zValidator('json', computeSchema),
  async (c) => {
    // ✅ Data validated & parsed
    const data = c.req.valid('json')
  }
)
```

---

## 7. Error Handling

```typescript
import { HTTPException } from 'hono/http-exception'

// ✅ Structured errors
if (!user) throw new HTTPException(404, { message: 'User not found' })
if (!hasAccess) throw new HTTPException(403, { message: 'Forbidden' })
if (tooManyRequests) throw new HTTPException(429, { message: 'Rate limited' })

// ✅ Global handler
app.onError((err, c) => {
  if (err instanceof HTTPException) return err.getResponse()
  
  logger.error('Unhandled error', {
    requestId: c.get('requestId'),
    error: err instanceof Error ? err.message : String(err),
  })
  
  return c.json({ error: 'Internal server error' }, 500)
})

// ❌ Silent catch
try { await operation() } catch { }

// ✅ Explicit handling
try { await operation() } catch (err) {
  logger.error('Operation failed', { error: err })
  throw new HTTPException(500, { message: 'Failed' })
}
```

