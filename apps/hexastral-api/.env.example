# hexastral-api — Cloudflare Worker Secrets
# Copy to .env.production.secrets and fill in real values.
# Upload with: bun secrets:sync (calls scripts/sync-secrets.js)
# These are secrets — do NOT put them in wrangler.jsonc [vars].

# Shared internal service-to-service auth key.
# Generate with: openssl rand -hex 32
INTERNAL_KEY=

# RevenueCat webhook verification (Settings → Webhooks → Authorization header).
REVENUECAT_WEBHOOK_SECRET=

# Cloudflare Turnstile secret key (used to verify web form submissions).
# Get from: Cloudflare Dashboard → Turnstile → your site → Secret Key
TURNSTILE_SECRET=
