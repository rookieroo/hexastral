{
  "name": "@zhop/astro-i18n",
  "version": "0.1.0",
  "description": "Locale dictionaries that render canonical Chinese metaphysics tokens (干支/五行/十神/格局/神煞/紫微星/四化/12宫/时辰) into target-locale strings.",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./labelize": {
      "types": "./src/labelize.ts",
      "default": "./src/labelize.ts"
    },
    "./dictionaries/*": {
      "types": "./src/dictionaries/*.ts",
      "default": "./src/dictionaries/*.ts"
    }
  },
  "devDependencies": {
    "@zhop/typescript-config": "workspace:*",
    "typescript": "^5.9.3"
  }
}
