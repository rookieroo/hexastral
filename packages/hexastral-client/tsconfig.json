{
  "extends": "@zhop/typescript-config/base.json",
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "noEmit": true,
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "types": ["@cloudflare/workers-types/2023-07-01"]
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules"]
}
